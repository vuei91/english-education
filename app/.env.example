# Copy this file to `.env` and fill in the real values from the Supabase
# dashboard (Settings → API Keys).
#
# Use the NEW key model:
#   - Publishable key : sb_publishable_... — client-safe, rotatable, auditable.
#     (Replaces the legacy JWT `anon` key. Both still work in the SDK during
#      the transition period, but new projects should prefer publishable.)
#   - Secret key      : sb_secret_... — server-only. MUST NOT appear here.
#
# Expo only forwards variables prefixed with EXPO_PUBLIC_ to the client
# bundle, which is exactly what we want for the publishable key.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
